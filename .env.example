# Hold-to-talk hotkey (press+hold to record, release to process)
# Supports chords: last key is primary (press/release), others are required modifiers.
# Examples: alt+x , ctrl+shift+space , scroll lock , f8
HOTKEY=alt+x
# Extra key held together with HOTKEY for AI-refined replies (e.g. z → Alt+X+Z)
AI_MODIFIER=z

# Audio settings
SAMPLE_RATE=16000
CHANNELS=1

# Local Whisper settings
# 'tiny.en' (fastest English), 'base.en', 'small.en'
WHISPER_MODEL_SIZE=tiny.en
# 'cpu' or 'cuda' (auto-detected if blank)
WHISPER_DEVICE=auto

# Refinement LLM settings
# Flip this to switch backends: 'ollama' | 'openrouter' | 'none'
LLM_PROVIDER=ollama
# Ollama model tag (local). Examples: qwen2.5:1.5b-instruct , llama3.2:3b , phi4-mini
LLM_MODEL=qwen2.5:1.5b-instruct
# OpenRouter model slug (cloud). Used when LLM_PROVIDER=openrouter.
# Browse models: https://openrouter.ai/models
OPENROUTER_MODEL=google/gemini-2.0-flash-001
# Local Ollama OpenAI-compatible endpoint (ignored for openrouter when still localhost)
LLM_API_BASE=http://localhost:11434/v1
# OpenRouter OpenAI-compatible endpoint (default is fine for most users)
OPENROUTER_API_BASE=https://openrouter.ai/api/v1
# Max response token limit to control latency vs length (e.g. 150)
LLM_MAX_TOKENS=150
# Ollama context window (higher = smarter multi-turn, slightly slower)
LLM_NUM_CTX=2048
# Required when LLM_PROVIDER=openrouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Timing & Feedback
PASTE_DELAY_SECONDS=0.05
PLAY_AUDIO_CUES=true
SHOW_VISUAL_INDICATOR=true
# Ignore accidental taps shorter than this (milliseconds)
MIN_HOLD_MS=80
# Cooldown between finished cycle and next capture (milliseconds)
RETRIGGER_COOLDOWN_MS=120
