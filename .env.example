# Hold-to-talk hotkey (press+hold to record, release to process)
# Examples: ctrl+shift+space , scroll lock , f8
HOTKEY=ctrl+shift+space

# Audio settings
SAMPLE_RATE=16000
CHANNELS=1

# Local Whisper settings
# 'tiny.en' (fastest English), 'base.en', 'small.en'
WHISPER_MODEL_SIZE=tiny.en
# 'cpu' or 'cuda' (auto-detected if blank)
WHISPER_DEVICE=auto

# Refinement LLM settings
# Options: 'ollama', 'openrouter', 'none'
LLM_PROVIDER=ollama
# For Ollama e.g., 'qwen2.5:1.5b-instruct', 'llama3.2:3b'. For OpenRouter e.g., 'nvidia/llama-3.1-nemotron-51b-instruct'
LLM_MODEL=qwen2.5:1.5b-instruct
# Local Ollama endpoint
LLM_API_BASE=http://localhost:11434/v1
# Max response token limit to control latency vs length (e.g. 150)
LLM_MAX_TOKENS=150
# Ollama context window (higher = smarter multi-turn, slightly slower)
LLM_NUM_CTX=2048
# API Key (only needed if provider is openrouter)
OPENROUTER_API_KEY=

# Timing & Feedback
PASTE_DELAY_SECONDS=0.05
PLAY_AUDIO_CUES=true
SHOW_VISUAL_INDICATOR=true
# Ignore accidental taps shorter than this (milliseconds)
MIN_HOLD_MS=80
# Cooldown between finished cycle and next capture (milliseconds)
RETRIGGER_COOLDOWN_MS=120
